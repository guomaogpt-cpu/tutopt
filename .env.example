# Application
NODE_ENV=development
LOG_LEVEL=info

# Public (exposed to browser)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database
DATABASE_URL="postgresql://tutopt:tutopt@localhost:5433/tutopt?schema=public"

# OTP signing (optional — falls back to DATABASE_URL)
# OTP_SECRET=change-me-otp-secret

# SMS provider (optional — not required in development; OTP is logged to console)
# SMS_PROVIDER=console

# Temporary: allow OTP codes in API/UI on production without SMS (Railway testing only).
# Default/off when unset. MUST be false for real users.
DEMO_OTP_ENABLED=false

# Google OAuth (optional — phone/password works without these)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# First admin (used only by `npm run admin:create`)
# ADMIN_EMAIL=admin@tutopt.kg
# ADMIN_PHONE=+996700000000
# ADMIN_NAME=Tutopt Admin
# ADMIN_PASSWORD=change-me-strong-password
